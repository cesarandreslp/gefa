{
  "name": "gefa",
  "version": "0.1.0",
  "private": true,
  "description": "GEFA — Plataforma SaaS multitenant de Gestión Familiar para Comisarías de Familia",
  "author": "GEFA",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate && npm run db:tenant-schema",
    "db:generate": "prisma generate",
    "db:tenant-schema": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/tenant-schema.sql",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} prisma/seed.ts",
    "db:seed:family": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} prisma/seed-family.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@vercel/blob": "^2.0.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^3.0.0",
    "groq-sdk": "^0.37.0",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "next": "^14.0.0",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autocannon": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
