# ============================================================================
# VARIABLES DE ENTORNO - VENTANILLA ÚNICA
# ============================================================================
# IMPORTANTE: Copiar este archivo como .env.local y completar los valores
# NUNCA hacer commit de .env.local (está en .gitignore)
# ============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Obtener de: https://neon.tech
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/ventanilla_unica?sslmode=require"

# -----------------------------------------------------------------------------
# MULTITENANCY - DOMINIO PROPIO
# -----------------------------------------------------------------------------
# Dominio base bajo el que cada tenant vive en su subdominio: <sigla>.ossgefa.lat
# Con un wildcard `*.ossgefa.lat` (DNS + Vercel) cualquier subdominio resuelve
# solo: el primer label se usa como `sigla` del tenant (ver tenantResolver.ts).
# Default si no se define: ossgefa.lat
TENANT_BASE_DOMAIN="ossgefa.lat"

# API de Neon para el provisioning automático de tenants (Fase 2): al dar de alta una
# Alcaldía se crea su PROPIO proyecto Neon (`gefa-<sigla>`), se le aplica el esquema y
# se siembra. Se obtiene en Neon → Account settings → API keys. NUNCA commitear el
# valor real (va solo en .env / Vercel env).
NEON_API_KEY="napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Organización Neon donde se crean los proyectos de los tenants (API keys org-scoped
# exigen org_id). Obtener en /users/me/organizations o en Organization settings.
NEON_ORG_ID="org-xxxxxxxxxxxxxxxx"
# Región AWS para los proyectos nuevos (debe coincidir con la del control plane).
NEON_PROJECT_REGION="aws-us-east-1"

# -----------------------------------------------------------------------------
# SEGURIDAD - JWT (FASE 2)
# -----------------------------------------------------------------------------
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OBLIGATORIO: Cambiar en producción
JWT_SECRET="CAMBIAR_POR_SECRET_ALEATORIO_SEGURO"
JWT_EXPIRATION="8h"

# -----------------------------------------------------------------------------
# ALMACENAMIENTO - VERCEL BLOB (FASE 2)
# -----------------------------------------------------------------------------
# Token de lectura/escritura para Vercel Blob Storage
# Obtener de: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXX"

# -----------------------------------------------------------------------------
# SEGURIDAD - ENCRIPTACIÓN
# -----------------------------------------------------------------------------
# Clave para encriptar datos sensibles
ENCRYPTION_KEY="CAMBIAR_POR_KEY_ALEATORIA_32_BYTES"

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_VERSION="v1"
API_BASE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
NODE_ENV="development"
PORT="3000"

# -----------------------------------------------------------------------------
# NOTIFICACIONES - EMAIL (FASE 3)
# -----------------------------------------------------------------------------
# Configurar con servidor SMTP institucional
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="personeria@guadalajaradebuga.gov.co"
SMTP_PASS="PASSWORD_SMTP"
EMAIL_FROM="personeria@guadalajaradebuga.gov.co"
EMAIL_FROM_NAME="Personería Municipal - Guadalajara de Buga"

# -----------------------------------------------------------------------------
# NOTIFICACIONES - SMS (Opcional - Fase futura)
# -----------------------------------------------------------------------------
# SMS_PROVIDER="twilio"
# SMS_ACCOUNT_SID=""
# SMS_AUTH_TOKEN=""
# SMS_PHONE_NUMBER=""

# -----------------------------------------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS
# -----------------------------------------------------------------------------
# Opciones: "local" o "s3"
STORAGE_PROVIDER="local"
STORAGE_PATH="./uploads"
MAX_FILE_SIZE_MB="10"

# Si se usa S3 (AWS, DigitalOcean Spaces, etc.):
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""

# -----------------------------------------------------------------------------
# LÍMITES Y SEGURIDAD
# -----------------------------------------------------------------------------
# Rate limiting (requests por ventana de tiempo)
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutos
RATE_LIMIT_MAX_REQUESTS="100"

# Intentos de login fallidos antes de bloqueo
MAX_LOGIN_ATTEMPTS="5"
ACCOUNT_LOCK_TIME_MINUTES="60"

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL="info"  # error, warn, info, debug, trace
LOG_TO_FILE="false"
LOG_FILE_PATH="./logs"

# -----------------------------------------------------------------------------
# CARACTERÍSTICAS OPCIONALES (Fase futura)
# -----------------------------------------------------------------------------
# ENABLE_2FA="false"
# ENABLE_SIGNATURE="false"
# ENABLE_OCR="false"

# -----------------------------------------------------------------------------
# DATOS INSTITUCIONALES
# -----------------------------------------------------------------------------
INSTITUTION_NAME="Personería Municipal de Guadalajara de Buga"
INSTITUTION_NIT="890399119-1"
INSTITUTION_ADDRESS="Carrera 13 No. 6-45"
INSTITUTION_CITY="Guadalajara de Buga"
INSTITUTION_DEPARTMENT="Valle del Cauca"
INSTITUTION_PHONE="(+57) 2 2363636"
INSTITUTION_EMAIL="personeria@guadalajaradebuga.gov.co"
INSTITUTION_WEBSITE="https://www.guadalajaradebuga.gov.co"

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE TÉRMINOS
# -----------------------------------------------------------------------------
# Primer día laboral de la semana (1=Lunes)
FIRST_BUSINESS_DAY="1"
# Último día laboral de la semana (5=Viernes)
LAST_BUSINESS_DAY="5"
